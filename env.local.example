# Supabase project credentials
# Find these in your Supabase dashboard under Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used for OAuth redirect construction in production.
# Set this to your deployed URL (e.g. https://your-app.vercel.app).
# Not required for local dev (defaults to http://localhost:3000).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: dev-only performance logging (used by lib/dev/route-bench.ts).
# Leave unset in production.
# ROUTE_BENCH=1
# BENCH_TRACK_SESSION=1
